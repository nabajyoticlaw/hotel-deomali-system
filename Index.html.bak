<!DOCTYPE html>
<html>
  <head>
    <base target="_top">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
    <style>
      body { background-color: #f4f4f4; }
      .hotel-card { margin-top: 20px; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="row">
        <div class="col s12">
          <div class="card hotel-card">
            <div class="card-image">
              <img id="hotelImage" src="https://via.placeholder.com/600x300">
              <span class="card-title" id="hotelName">Hotel Name</span>
            </div>
            <div class="card-content">
              <p id="about">Loading...</p>
              <br>
              <p><strong>Contact:</strong> <span id="phone"></span> | <span id="email"></span></p>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <script>
      // Fetch dynamic data from the GAS server side
      google.script.run.withSuccessHandler(function(data) {
        document.getElementById('hotelName').innerText = data.hotelName;
        document.getElementById('about').innerText = data.about;
        document.getElementById('phone').innerText = data.phone;
        document.getElementById('email').innerText = data.email;
        document.getElementById('hotelImage').src = data.imageUrl;
      }).getHotelData();
    </script>
  </body>
</html>